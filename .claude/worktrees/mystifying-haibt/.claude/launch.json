{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--port", "8082"],
      "port": 8082,
      "autoPort": true
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--web"],
      "port": 8081,
      "autoPort": true
    },
    {
      "name": "iOS",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "run:ios"],
      "port": 8081,
      "autoPort": true
    },
    {
      "name": "Android",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "run:android"],
      "port": 8081,
      "autoPort": true
    }
  ]
}
